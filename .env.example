# OtterFlow Analytics — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez les valeurs

# ─── Connexion RDV Auto ───────────────────────────────────────────────────────
# URL de l'API de l'application RDV Auto (laisser vide pour le mode démo)
RDV_AUTO_API_URL=

# Clé API pour authentifier les requêtes vers RDV Auto
RDV_AUTO_API_KEY=

# Secret HMAC pour valider les signatures des webhooks entrants depuis RDV Auto
# Générez une valeur aléatoire sécurisée : openssl rand -hex 32
RDV_AUTO_WEBHOOK_SECRET=

# ─── Configuration optionnelle ───────────────────────────────────────────────
# Intervalle de polling en secondes (défaut: 30)
# NEXT_PUBLIC_POLLING_INTERVAL=30
