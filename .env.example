# OtterFlow / RDV Auto — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez les valeurs

# ─── Supabase ────────────────────────────────────────────────────────────────
# Créez un projet sur https://supabase.com et récupérez ces valeurs dans
# Settings › API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clé service role (ne jamais exposer côté client — server-only)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Resend (emails de confirmation et rappel J-1) ────────────────────────────
# Créez un compte sur https://resend.com et obtenez une clé API
RESEND_API_KEY=re_xxx
# Adresse expéditeur (domaine vérifié dans Resend)
RESEND_FROM=RDV Auto <noreply@votredomaine.fr>

# ─── Application ─────────────────────────────────────────────────────────────
# URL publique de l'app (utilisée pour construire les liens dans les emails)
NEXT_PUBLIC_APP_URL=https://votredomaine.fr

# ─── Connexion RDV Auto (legacy — plus utilisé) ──────────────────────────────
# RDV_AUTO_API_URL=
# RDV_AUTO_API_KEY=
# RDV_AUTO_WEBHOOK_SECRET=
